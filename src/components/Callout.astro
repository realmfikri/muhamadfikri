---
interface Props {
  title?: string;
}

const { title = 'Key Takeaways' } = Astro.props;
---

<aside class="card border-l-4 border-l-cyan-500 p-5">
  <h3 class="text-lg font-semibold text-slate-900 dark:text-white">{title}</h3>
  <div class="mt-3 text-slate-700 dark:text-slate-300">
    <slot />
  </div>
</aside>
