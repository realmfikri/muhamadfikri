---
interface TimelineItem {
  title: string;
  period: string;
  description: string;
}

interface Props {
  items: TimelineItem[];
}

const { items } = Astro.props;
---

<ol class="relative border-s border-slate-300 ps-6 dark:border-slate-700">
  {items.map((item) => (
    <li class="mb-10 ms-4 last:mb-0">
      <span class="absolute -start-[9px] mt-1 h-4 w-4 rounded-full border-2 border-cyan-500 bg-white dark:bg-slate-950"></span>
      <p class="text-sm font-semibold uppercase tracking-[0.1em] text-cyan-700 dark:text-cyan-300">{item.period}</p>
      <h3 class="mt-1 text-xl font-semibold text-slate-900 dark:text-white">{item.title}</h3>
      <p class="mt-2 text-slate-700 dark:text-slate-300">{item.description}</p>
    </li>
  ))}
</ol>
