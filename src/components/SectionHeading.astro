---
interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
}

const { title, description, eyebrow } = Astro.props;
---

<div class="mb-6 max-w-3xl">
  {eyebrow && (
    <p class="text-sm font-semibold uppercase tracking-[0.12em] text-cyan-700 dark:text-cyan-300">{eyebrow}</p>
  )}
  <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl">{title}</h2>
  {description && <p class="mt-3 text-lg text-slate-700 dark:text-slate-300">{description}</p>}
</div>
