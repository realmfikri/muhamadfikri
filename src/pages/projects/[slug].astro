---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';
import Callout from '../../components/Callout.astro';

export async function getStaticPaths() {
  const projects = (await getCollection('projects')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const sortedProjects = (await getCollection('projects')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const { project } = Astro.props as { project: CollectionEntry<'projects'> };
const { Content } = await render(project);

const index = sortedProjects.findIndex((item) => item.slug === project.slug);
const nextProject = index > 0 ? sortedProjects[index - 1] : undefined;
const prevProject = index < sortedProjects.length - 1 ? sortedProjects[index + 1] : undefined;

const statusClassMap = {
  active: 'text-emerald-700 bg-emerald-100 border-emerald-300 dark:text-emerald-200 dark:bg-emerald-900/40 dark:border-emerald-700',
  paused: 'text-amber-700 bg-amber-100 border-amber-300 dark:text-amber-200 dark:bg-amber-900/40 dark:border-amber-700',
  completed: 'text-slate-700 bg-slate-100 border-slate-300 dark:text-slate-200 dark:bg-slate-800 dark:border-slate-700'
};

const projectJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.data.title,
  description: project.data.tagline,
  url: `https://muhamadfikri.com/projects/${project.slug}`,
  datePublished: project.data.date.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Muhamad Fikri'
  }
};
---

<BaseLayout
  path={`/projects/${project.slug}`}
  title={`${project.data.title} Project`}
  description={project.data.tagline}
  type="article"
  jsonLd={projectJsonLd}
>
  <article class="grid gap-8 lg:grid-cols-[2.2fr_1fr]">
    <div>
      <a href="/projects" class="text-sm font-medium text-cyan-700 underline underline-offset-4 dark:text-cyan-300">
        ← Back to all projects
      </a>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-900 dark:text-white">{project.data.title}</h1>
      <p class="mt-4 text-lg leading-8 text-slate-700 dark:text-slate-300">{project.data.tagline}</p>

      <div class="mt-5 flex flex-wrap gap-2">
        {project.data.tags.map((tag) => (
          <Badge label={tag} />
        ))}
      </div>

      <div class="mt-8">
        <Callout title="Key Takeaways">
          <ul class="list-disc space-y-1.5 pl-5">
            {project.data.highlights.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </Callout>
      </div>

      <div class="card prose-content mt-8 p-6 sm:p-8">
        <Content />
      </div>

      <nav class="mt-8 grid gap-4 sm:grid-cols-2" aria-label="Project navigation">
        <div class="card p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.1em] text-slate-600 dark:text-slate-400">Previous project</p>
          {prevProject ? (
            <a
              href={`/projects/${prevProject.slug}`}
              class="mt-2 inline-block text-lg font-semibold text-slate-900 underline underline-offset-4 hover:text-cyan-700 dark:text-white dark:hover:text-cyan-300"
            >
              {prevProject.data.title}
            </a>
          ) : (
            <p class="mt-2 text-slate-600 dark:text-slate-300">No previous project.</p>
          )}
        </div>

        <div class="card p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.1em] text-slate-600 dark:text-slate-400">Next project</p>
          {nextProject ? (
            <a
              href={`/projects/${nextProject.slug}`}
              class="mt-2 inline-block text-lg font-semibold text-slate-900 underline underline-offset-4 hover:text-cyan-700 dark:text-white dark:hover:text-cyan-300"
            >
              {nextProject.data.title}
            </a>
          ) : (
            <p class="mt-2 text-slate-600 dark:text-slate-300">No next project.</p>
          )}
        </div>
      </nav>
    </div>

    <aside class="space-y-5">
      <section class="card p-5">
        <h2 class="text-sm font-semibold uppercase tracking-[0.1em] text-slate-700 dark:text-slate-300">Project facts</h2>
        <dl class="mt-4 space-y-3 text-sm">
          <div>
            <dt class="font-semibold text-slate-900 dark:text-white">Status</dt>
            <dd>
              <span
                class={`mt-1 inline-flex rounded-full border px-2.5 py-1 text-xs font-medium ${statusClassMap[project.data.status]}`}
              >
                {project.data.status}
              </span>
            </dd>
          </div>
          <div>
            <dt class="font-semibold text-slate-900 dark:text-white">Role</dt>
            <dd class="mt-1 text-slate-700 dark:text-slate-300">{project.data.role}</dd>
          </div>
          <div>
            <dt class="font-semibold text-slate-900 dark:text-white">Updated</dt>
            <dd class="mt-1 text-slate-700 dark:text-slate-300">{project.data.date.toISOString().slice(0, 10)}</dd>
          </div>
        </dl>
      </section>

      <section class="card p-5">
        <h2 class="text-sm font-semibold uppercase tracking-[0.1em] text-slate-700 dark:text-slate-300">Tech stack</h2>
        <div class="mt-3 flex flex-wrap gap-2">
          {project.data.stack.map((item) => (
            <Badge label={item} />
          ))}
        </div>
      </section>

      <section class="card p-5">
        <h2 class="text-sm font-semibold uppercase tracking-[0.1em] text-slate-700 dark:text-slate-300">Links</h2>
        <ul class="mt-3 space-y-2">
          {project.data.links.map((link) => (
            <li>
              <a
                href={link.url}
                target="_blank"
                rel="noreferrer"
                class="font-medium text-cyan-700 underline underline-offset-4 hover:text-cyan-600 dark:text-cyan-300"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </section>
    </aside>
  </article>
</BaseLayout>
