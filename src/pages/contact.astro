---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { siteConfig } from '../data/site';

const contacts = [
  { label: 'Email', value: siteConfig.email, href: `mailto:${siteConfig.email}` },
  { label: 'LinkedIn', value: 'muhamad-f-10166a132', href: 'https://www.linkedin.com/in/muhamad-f-10166a132/' },
  { label: 'GitHub', value: 'realmfikri', href: 'https://github.com/realmfikri' },
  { label: 'X', value: '@Himposing', href: 'https://x.com/Himposing' }
];
---

<BaseLayout
  path="/contact"
  title="Contact"
  description="Contact Muhamad Fikri via email, LinkedIn, GitHub, or X."
>
  <section class="card p-8 sm:p-10">
    <SectionHeading
      eyebrow="Contact"
      title="Let’s Connect"
      description="Best for internship, collaboration, backend/systems roles, or project discussions."
    />

    <div class="grid gap-4 md:grid-cols-2">
      {contacts.map((contact) => (
        <a
          href={contact.href}
          target={contact.href.startsWith('mailto:') ? undefined : '_blank'}
          rel={contact.href.startsWith('mailto:') ? undefined : 'noreferrer'}
          class="card block p-5 transition hover:-translate-y-0.5 hover:shadow-lg"
        >
          <p class="text-sm font-semibold uppercase tracking-[0.1em] text-cyan-700 dark:text-cyan-300">{contact.label}</p>
          <p class="mt-2 text-lg font-semibold text-slate-900 dark:text-white">{contact.value}</p>
        </a>
      ))}
    </div>

    <div class="mt-8">
      <a href={`mailto:${siteConfig.email}`} class="button-primary">Start an Email Conversation</a>
    </div>
  </section>
</BaseLayout>
