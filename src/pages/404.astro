---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  path="/404"
  title="Page Not Found"
  description="The page you requested does not exist on muhamadfikri.com."
>
  <section class="card mx-auto max-w-2xl p-10 text-center">
    <p class="text-sm font-semibold uppercase tracking-[0.12em] text-cyan-700 dark:text-cyan-300">404</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900 dark:text-white">Page not found</h1>
    <p class="mt-4 text-slate-700 dark:text-slate-300">
      The page may have moved, or the URL may be incorrect.
    </p>
    <div class="mt-8">
      <a href="/" class="button-primary">Back to homepage</a>
    </div>
  </section>
</BaseLayout>
